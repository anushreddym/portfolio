---
import "../styles/landing.css"
import logoImage from "../assets/logo.png"
import solarsystemImage from "../assets/orrery.png"
import puzzlecubeImage from "../assets/puzzlecube.png"
import slingshot from "../assets/slingshot.png"
import holesImage from "../assets/holes.png"
import Tile from "../components/Tile.astro"
---



<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://kit.fontawesome.com/f00d779dcd.js" crossorigin="anonymous"></script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Ubuntu:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500;1,700&display=swap" rel="stylesheet">

    <title>Portfolio</title>
</head>
<body>
    <div class="holder">
        <header class="header">
            <ul class="header-list">
                <li class="header-item" id="prj">
                    <a href="#projects">Projects</a>
                </li>
                <li class="header-item">
                    <a href="#contact">Contact</a>
                </li>
            </ul>
        </header>
    
        <div class="wrapper">
            <div class="info">
                <h1 class="title">>‎ ‎ ‎  Hey, I'm <mark class="blue">Anush.</mark></h1>
                <p class="description">High school student and game development enthusiast exploring code and technology.</p>
                <p class="chkprj">Check out my <mark class="blue"><a href="#projects" class="prj_link">projects</a></mark> and more below.</p>
            </div>
    
            <div class="about">
                <h1 class="about_text">About Me</h1>
                <div class="section">
                    <h1 class="section_title">>‎ ‎ Based in</h1>
                    <p class="section_description"><mark class="purple">California</mark></p>
                </div>
                <div class="section">
                    <h1 class="section_title">>‎ ‎ Contact</h1>
                    <p class="section_description"><mark class="purple">anushmudiganti@gmail.com</mark></p>
                </div>
                <div class="section">
                    <h1 class="section_title">>‎ ‎ Hobbies</h1>
                    <p class="section_description"><mark class="purple">Gaming, Biking, Piano, Game Development</mark></p>
                </div>
                <div class="section">
                    <h1 class="section_title">>‎ ‎ Skills</h1>
                    <p class="section_description"><mark class="purple">Java, HTML, CSS, Lua, C#, GDScript</mark></p>
                </div>
                <div class="section">
                    <h1 class="section_title">>‎ ‎ Latest Project</h1>
                    <p class="section_description"><mark class="purple">Coming Soon...</mark></p>
                </div>
            </div>
    
            <div class="projects">
                <h1 class="prj_title">>‎ ‎  Projects</h1>
    
                <Tile 
                image={solarsystemImage.src} 
                name="Orrery Model" 
                description="Made in Godot with GDscript. This was my first completed project in Godot. This was a huge learning opportunity and I hope to improve this in the future." 
                techUsed={['Godot', 'GDscript', '2D Physics', 'Game Design', 'Orbit Simulation']} 
                />
    
                <Tile 
                image={solarsystemImage.src} 
                name="Orrery Model" 
                description="Made in Godot with GDscript. This was my first completed project in Godot. This was a huge learning opportunity and I hope to improve this in the future." 
                techUsed={['Godot', 'GDscript', '2D Physics', 'Game Design', 'Orbit Simulation']} 
                />
    
                <Tile 
                image={solarsystemImage.src} 
                name="Orrery Model" 
                description="Made in Godot with GDscript. This was my first completed project in Godot. This was a huge learning opportunity and I hope to improve this in the future." 
                techUsed={['Godot', 'GDscript', '2D Physics', 'Game Design', 'Orbit Simulation']} 
                />
            </div>
        </div>
    </div>
</body>

<script is:inline>
    let positionX = 0;
    let positionY = 0;

    function moveBackground() {
        positionX += 0.05; 
        positionY += 0.05;
        document.body.style.backgroundPosition = `${positionX}px ${positionY}px`;
        requestAnimationFrame(moveBackground); 
    }

    moveBackground(); 
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
    console.log("project button test");
    const projectButton = document.querySelector(".header-item#prj");
    const projectLink = document.querySelector(".prj_link");
    const targetSection = document.querySelector(".projects");

    if(projectButton && targetSection) {
        projectButton.addEventListener("click", () => {
            targetSection.scrollIntoView({behavior: "smooth", block: "center"});
        });
    }
    if(projectLink && targetSection) {
        projectLink.addEventListener("click", () => {
            targetSection.scrollIntoView({behavior: "smooth", block: "center"});
        });
    }

    });
</script>
</html>