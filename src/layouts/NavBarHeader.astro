---
import ("../styles/navbar.css")
---

<script src="https://kit.fontawesome.com/f00d779dcd.js" crossorigin="anonymous"></script>

<header class="header">
    <nav class="nav">
        <ul class="nav_list">
            <li class="nav_item">
                <a href="#" class="nav_link" id="home">Home</a>
            </li>
            <li class="nav_item">
                <a href="#" class="nav_link" id="about">About</a>
            </li>
            <li class="nav_item">
                <a href="#" class="nav_link" id="projects">Projects</a>
            </li>
            <li class="nav_item">
                <a href="#" class="nav_link" id="contact">Contact</a>
            </li>
        </ul>
        <div class="toggle_button">
            <i class="fa-solid fa-bars fa-xl" id="menu-icon"></i>
            <i class="fa-solid fa-x fa-xl" id="close-icon" style="display: none;"></i>
        </div>
        <div class="drop_menu">
            <li class="drop_item">
                <a href="#" class="drop_link" id="home">Home</a>
            </li>
            <li class="drop_item">
                <a href="#" class="drop_link" id="about">About</a>
            </li>
            <li class="drop_item">
                <a href="#" class="drop_link" id="projects">Projects</a>
            </li>
            <li class="drop_item">
                <a href="#" class="drop_link" id="contact">Contact</a>
            </li>
        </div>
    </nav>
</header>

<script>
    const toggleButton = document.querySelector('.toggle_button') as HTMLElement;
    const dropMenu = document.querySelector('.drop_menu') as HTMLElement;
    const body = document.body;
    const menuIcon = document.getElementById('menu-icon') as HTMLElement;
    const closeIcon = document.getElementById('close-icon') as HTMLElement;

    function hideMenu() {
        if (dropMenu) {
            dropMenu.style.left = '-100%';
            dropMenu.style.display = 'none'; 
            body.classList.remove('menu-open');
        }
        if (menuIcon && closeIcon) {
            menuIcon.style.display = 'block'; 
            closeIcon.style.display = 'none'; 
        }
        if (toggleButton) {
            toggleButton.classList.remove('active');
        }
    }

    if (toggleButton) {
        toggleButton.addEventListener('click', () => {
            toggleButton.classList.toggle('active');

            if (toggleButton.classList.contains('active')) {
                if (dropMenu) {
                    dropMenu.style.display = 'flex';
                    setTimeout(() => {
                        dropMenu.style.left = '0'; 
                        body.classList.add('menu-open');
                    }, 10); 
                }
                if (menuIcon && closeIcon) {
                    menuIcon.style.display = 'none'; 
                    closeIcon.style.display = 'block'; 
                }
            } else {
                if (dropMenu) {
                    dropMenu.style.left = '-100%'; 
                    setTimeout(() => {
                        dropMenu.style.display = 'none'; 
                        body.classList.remove('menu-open');
                    }, 300); 
                }
                if (menuIcon && closeIcon) {
                    menuIcon.style.display = 'block'; 
                    closeIcon.style.display = 'none'; 
                }
            }
        });
    }
    window.addEventListener('resize', () => {
        if (window.innerWidth >= 635) {
            hideMenu(); 
        }
    });
</script>

