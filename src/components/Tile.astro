---
const { image, name, description, link, techUsed } = Astro.props;
import '../styles/tile.css';
---

<a href={link} target="_blank">
    <div class="project_tile">
        <img src={image} alt={name} class="project_image" />
        <div class="content">
            <h2 class="project_name">{name}</h2>
            <p class="project_description">{description}</p>
            <div class="tech_used">
                {techUsed.map((tech: unknown) => (
                    <p class="tech">{tech}</p>
                ))}
            </div>
        </div>
    </div>
</a>
